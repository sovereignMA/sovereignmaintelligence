# ═══════════════════════════════════════════════════════════════
# PROJECT SOVEREIGN — Required Environment Variables
# Set these in Vercel Project Settings → Environment Variables
# Set edge-function secrets in Supabase Dashboard → Edge Functions → Secrets
# ═══════════════════════════════════════════════════════════════

# ── App URL ─────────────────────────────────────────────────────
APP_URL=https://sovereigncmd.xyz

# ── Vercel Cron Protection ───────────────────────────────────────
# Generate: openssl rand -hex 32
# Must also be set as a Supabase Edge Function secret
CRON_SECRET=your-secret-here

# ── Supabase ─────────────────────────────────────────────────────
# Set in Vercel env vars AND as Supabase Edge Function secrets
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# NOTE: SUPABASE_ANON_KEY is a PUBLIC key — safe in client-side JS (protected by RLS)
# Rotate in Supabase Dashboard → Settings → API if compromised
SUPABASE_ANON_KEY=your-anon-key

# ── Anthropic AI ─────────────────────────────────────────────────
# Set in Vercel env vars AND as a Supabase Edge Function secret
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Stripe ───────────────────────────────────────────────────────
# Dashboard: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
# Dashboard: https://dashboard.stripe.com/webhooks
# Endpoint: https://sovereigncmd.xyz/api/stripe/webhook
# Events: checkout.session.completed, customer.subscription.updated,
#         customer.subscription.deleted, invoice.payment_failed, invoice.paid
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs — Dashboard: https://dashboard.stripe.com/products
# Create 4 products: Prospector £99/mo, Dealmaker £299/mo, Deal Team £799/mo, Fund £2500/mo
STRIPE_PRICE_PROSPECTOR_MONTHLY=price_...
STRIPE_PRICE_PROSPECTOR_ANNUAL=price_...
STRIPE_PRICE_DEALMAKER_MONTHLY=price_...
STRIPE_PRICE_DEALMAKER_ANNUAL=price_...
STRIPE_PRICE_TEAM_MONTHLY=price_...
STRIPE_PRICE_TEAM_ANNUAL=price_...
STRIPE_PRICE_FUND_MONTHLY=price_...
STRIPE_PRICE_FUND_ANNUAL=price_...

# ── NVIDIA NIM PersonaPlex ────────────────────────────────────────────
# Set as Supabase Edge Function secrets
# Dashboard: https://build.nvidia.com/nvidia/personaplex-7b
# If not set, personaplex-proxy falls back to Claude automatically.
NVIDIA_NIM_API_KEY=nvapi-...
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com
# Set to "true" to route analytical agents (S1-S5, S7-S10, S15-S17) back to Claude
# while keeping dialogue agents (S11-S14, S18-S21) on PersonaPlex
# PERSONAPLEX_DIALOGUE_ONLY=true

# ── Companies House API ─────────────────────────────────────────────
# Get free API key: https://developer.company-information.service.gov.uk/
COMPANIES_HOUSE_API_KEY=...

# ── Email — Resend ────────────────────────────────────────────────
# Dashboard: https://resend.com/api-keys
RESEND_API_KEY=re_...
# From address (must be verified in Resend)
RESEND_FROM=notifications@sovereigncmd.xyz
# Internal notification recipient
NOTIFY_EMAIL=admin@sovereigncmd.xyz

# ── Twilio (agent calls/SMS) ──────────────────────────────────────
# Set as Supabase Edge Function secrets
TWILIO_ACCOUNT_SID=ACxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_FROM_NUMBER=+441234567890
HOWARD_PHONE=+447700000000
# WhatsApp sender number (must be Twilio-registered WhatsApp-enabled number)
TWILIO_WHATSAPP_FROM=whatsapp:+441234567890

# ── Tavily Search API (web scraper) ──────────────────────────────
# Set as a Supabase Edge Function secret
# Get key at: https://tavily.com
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── CORS / Edge Function config ──────────────────────────────────────────────
# Allowed origin for Supabase Edge Function CORS. Set to your domain in production.
# Defaults to * (all origins) if not set.
ALLOWED_ORIGIN=https://sovereigncmd.xyz

# ── LinkedIn Campaign Manager ─────────────────────────────────────────────────
# OAuth access token with r_ads scope — get from LinkedIn Developer App
# Set as a Supabase Edge Function secret
LINKEDIN_ACCESS_TOKEN=your-linkedin-access-token
