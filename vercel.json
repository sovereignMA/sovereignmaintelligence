{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "name": "sovereign",
  "crons": [
    {
      "path": "/api/cron/deal-score-refresh",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/self-improve",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/pipeline-health",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/health-check",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/intel-refresh",
      "schedule": "0 9 * * 1"
    },
    {
      "path": "/api/cron/scout-targets",
      "schedule": "0 7 * * 1"
    },
    {
      "path": "/api/cron/data-retention",
      "schedule": "0 23 * * *"
    },
    {
      "path": "/api/cron/weekly-briefing",
      "schedule": "0 17 * * 5"
    },
    {
      "path": "/api/cron/compliance-check",
      "schedule": "0 0 1 * *"
    }
  ],
  "functions": {
    "api/cron/*.js": {
      "maxDuration": 60
    },
    "api/stripe/checkout.js": {
      "maxDuration": 30
    },
    "api/stripe/portal.js": {
      "maxDuration": 15
    },
    "api/stripe/webhook.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/",
      "destination": "/index.html"
    },
    {
      "source": "/login",
      "destination": "/login.html"
    },
    {
      "source": "/command",
      "destination": "/command.html"
    },
    {
      "source": "/intelligence",
      "destination": "/intelligence.html"
    },
    {
      "source": "/pipeline",
      "destination": "/pipeline.html"
    },
    {
      "source": "/scout",
      "destination": "/scout.html"
    },
    {
      "source": "/comms",
      "destination": "/comms.html"
    },
    {
      "source": "/analytics",
      "destination": "/analytics.html"
    },
    {
      "source": "/vault",
      "destination": "/vault.html"
    },
    {
      "source": "/security",
      "destination": "/security.html"
    },
    {
      "source": "/admin",
      "destination": "/admin.html"
    },
    {
      "source": "/privacy",
      "destination": "/legal.html"
    },
    {
      "source": "/terms",
      "destination": "/legal.html"
    },
    {
      "source": "/cookies",
      "destination": "/legal.html"
    },
    {
      "source": "/resources",
      "destination": "/resources.html"
    },
    {
      "source": "/mediakit",
      "destination": "/mediakit.html"
    },
    {
      "source": "/media-kit",
      "destination": "/mediakit.html"
    },
    {
      "source": "/upgrade",
      "destination": "/upgrade.html"
    },
    {
      "source": "/pricing",
      "destination": "/upgrade.html"
    },
    {
      "source": "/mail",
      "destination": "/mail.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(), payment=()"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://cdnjs.cloudflare.com https://fonts.googleapis.com https://unpkg.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://fonts.gstatic.com; font-src 'self' https://fonts.gstatic.com; connect-src 'self' https://kicdjdxxdqtmetphipnn.supabase.co wss://kicdjdxxdqtmetphipnn.supabase.co https://gmail.googleapis.com https://fonts.gstatic.com https://cdn.jsdelivr.net; img-src 'self' data: blob: https:; frame-ancestors 'none';"
        }
      ]
    },
    {
      "source": "/(.*)\\.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate"
        }
      ]
    },
    {
      "source": "/(.*)\\.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/(.*)\\.css",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400, stale-while-revalidate=604800"
        }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store"
        }
      ]
    }
  ],
  "env": {},
  "cleanUrls": true,
  "trailingSlash": false,
  "outputDirectory": "public"
}